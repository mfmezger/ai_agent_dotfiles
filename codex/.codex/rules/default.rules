prefix_rule(
    pattern = ["uv", "run", "pytest"],
    decision = "allow",
)

prefix_rule(
    pattern = ["make", "test-vcr"],
    decision = "allow",
)

prefix_rule(
    pattern = ["git", "add"],
    decision = "allow",
)

prefix_rule(
    pattern = ["cargo", "build"],
    decision = "allow",
)

prefix_rule(
    pattern = ["cargo", "update"],
    decision = "allow",
)

prefix_rule(
    pattern = ["git", "commit"],
    decision = "prompt",
    justification = "Always ask before creating commits.",
    match = [
        "git commit -m test",
        "git commit --amend -m test",
    ],
)

prefix_rule(
    pattern = ["git", "push"],
    decision = "prompt",
    justification = "Always ask before pushing changes to a remote.",
    match = [
        "git push",
        "git push origin main",
    ],
)
prefix_rule(pattern=["uv", "run", "python"], decision="allow")
